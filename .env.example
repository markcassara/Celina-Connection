# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in Vercel Project Settings → Environment Variables.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps features.
# This is bundled into the frontend at build time, so it must exist during Vercel builds.
GOOGLE_MAPS_PLATFORM_KEY=""

# APP_URL: Canonical public URL for checkout redirects and self-references.
# For production on Vercel, set this to https://celinaconnection.com
APP_URL="https://celinaconnection.com"

# STRIPE_SECRET_KEY: Stripe secret key for processing payments.
STRIPE_SECRET_KEY=""

# Stripe Price IDs for subscriptions / plans.
STRIPE_PRICE_ID_BASIC="price_1TqhN9IQqe0SJtgjZY569vkL"

# Annual Plans
STRIPE_PRICE_ID_PRO_ANNUAL="price_1TqislIQqe0SJtgjvfYKRChx"
STRIPE_PRICE_ID_PREMIUM_ANNUAL="price_1TqirvIQqe0SJtgjTcWN8HAb"
STRIPE_PRICE_ID_ADDON_ANNUAL=""

# Monthly Plans
STRIPE_PRICE_ID_PRO_MONTHLY="price_1Tr7zkIQqe0SJtgjL2POPOUI"
STRIPE_PRICE_ID_PREMIUM_MONTHLY=""
STRIPE_PRICE_ID_ADDON_MONTHLY=""

