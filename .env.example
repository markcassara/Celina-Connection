# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in Vercel Project Settings → Environment Variables.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Optional: Celina AI uses Gemini Flash Lite by default for low-cost basic Q&A.
GEMINI_LITE_MODEL="gemini-3.1-flash-lite"

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps features.
# This is bundled into the frontend at build time, so it must exist during Vercel builds.
GOOGLE_MAPS_PLATFORM_KEY=""

# APP_URL: Canonical public URL for checkout redirects and self-references.
# For production on Vercel, set this to https://celinaconnection.com
APP_URL="https://celinaconnection.com"

# PUBLIC_SITE_URL: Canonical public URL used in email verification links.
PUBLIC_SITE_URL="https://www.celinaconnection.com"

# Preferred CRM-backed delivery: GoHighLevel / LeadConnector.
# Set these in Vercel to create/update the owner contact, tag it, and send verification/welcome email from GHL.
# Requires Private Integration scopes for contacts and conversations/messages.
GHL_API_KEY=""
GHL_LOCATION_ID=""
GHL_WELCOME_TAGS="celina-connection,owner-registration"

# Fallback email delivery for owner verification emails: Brevo API.
# Create an API key in Brevo, then verify the sender/domain in Brevo before sending.
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="mthedesigner@gmail.com"
BREVO_SENDER_NAME="Celina Connection"

# Optional fallback: SMTP email delivery for owner verification emails.
# Google Workspace/Gmail setup:
# 1. Enable 2-Step Verification on the sender account.
# 2. Create an App Password for Mail.
# 3. Use the Workspace email as SMTP_USER and the 16-character app password as SMTP_PASS.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="mark@legacywealthco.com"
SMTP_PASS="GOOGLE_WORKSPACE_APP_PASSWORD"
SMTP_FROM="Celina Connection <mark@legacywealthco.com>"

# Optional fallback: Resend API email delivery. Used only when Brevo and SMTP are not configured.
RESEND_API_KEY=""
EMAIL_FROM="Celina Connection <mark@legacywealthco.com>"

# STRIPE_SECRET_KEY: Stripe secret key for processing payments.
STRIPE_SECRET_KEY=""

# Stripe Price IDs for subscriptions / plans.
STRIPE_PRICE_ID_BASIC="price_1TqhN9IQqe0SJtgjZY569vkL"

# Annual Plans
STRIPE_PRICE_ID_PRO_ANNUAL="price_1TqislIQqe0SJtgjvfYKRChx"
STRIPE_PRICE_ID_PREMIUM_ANNUAL="price_1TqirvIQqe0SJtgjTcWN8HAb"
STRIPE_PRICE_ID_ADDON_ANNUAL=""

# Monthly Plans
STRIPE_PRICE_ID_PRO_MONTHLY="price_1Tr7zkIQqe0SJtgjL2POPOUI"
STRIPE_PRICE_ID_PREMIUM_MONTHLY=""
STRIPE_PRICE_ID_ADDON_MONTHLY=""

